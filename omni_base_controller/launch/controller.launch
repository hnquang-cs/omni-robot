<launch>
  <!-- Placeholder controller entry point for later simulation or hardware integration. -->
  <arg name="use_sim_time" default="false"/>

  <param name="use_sim_time" value="$(arg use_sim_time)"/>

  <node pkg="omni_base_controller" type="omni_kinematics.py" name="omni_kinematics" output="screen">
    <remap from="/cmd_vel" to="/cmd_vel"/>
  </node>
</launch>
